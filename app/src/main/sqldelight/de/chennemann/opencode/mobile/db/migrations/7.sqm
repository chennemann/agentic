CREATE TABLE servers (
  id TEXT NOT NULL PRIMARY KEY,
  url TEXT NOT NULL UNIQUE,
  last_connected_at INTEGER
);

CREATE TABLE projects (
  id TEXT NOT NULL PRIMARY KEY,
  server_id TEXT NOT NULL,
  name TEXT NOT NULL,
  path TEXT NOT NULL,
  pinned INTEGER NOT NULL DEFAULT 0 CHECK (pinned IN (0, 1)),
  FOREIGN KEY (server_id) REFERENCES servers(id) ON DELETE CASCADE
);

CREATE TABLE sessions (
  id TEXT NOT NULL PRIMARY KEY,
  project_id TEXT NOT NULL,
  title TEXT NOT NULL,
  path TEXT NOT NULL,
  pinned INTEGER NOT NULL DEFAULT 0 CHECK (pinned IN (0, 1)),
  FOREIGN KEY (project_id) REFERENCES projects(id) ON DELETE CASCADE
);

CREATE INDEX servers_last_connected_at_idx ON servers(last_connected_at DESC);
CREATE INDEX projects_server_id_idx ON projects(server_id);
CREATE INDEX projects_pinned_idx ON projects(server_id, pinned DESC, name COLLATE NOCASE);
CREATE INDEX sessions_project_id_idx ON sessions(project_id);
CREATE INDEX sessions_pinned_idx ON sessions(project_id, pinned DESC, title COLLATE NOCASE);
