

listMessageCache:
SELECT server_url, session_id, message_id, role, text, sort_key, created_at, completed_at, updated_at
FROM message_cache
WHERE server_url = ? AND session_id = ?
ORDER BY sort_key ASC;

upsertMessageCache:
INSERT INTO message_cache(
  server_url,
  session_id,
  message_id,
  role,
  text,
  sort_key,
  created_at,
  completed_at,
  updated_at
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(server_url, session_id, message_id) DO UPDATE SET
  role = excluded.role,
  text = excluded.text,
  sort_key = excluded.sort_key,
  created_at = excluded.created_at,
  completed_at = excluded.completed_at,
  updated_at = excluded.updated_at;

deleteMessageCache:
DELETE FROM message_cache
WHERE server_url = ? AND session_id = ? AND message_id = ?;

deleteMessageCacheSession:
DELETE FROM message_cache
WHERE server_url = ? AND session_id = ?;
